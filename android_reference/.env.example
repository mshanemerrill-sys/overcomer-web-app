# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Optional: PROGRAMMATIC FIREBASE CONFIGURATION
# If you don't use google-services.json, you can configure Firebase Auth programmatically
# by setting these variables in your AI Studio Secrets panel or .env file.
FIREBASE_API_KEY=MY_FIREBASE_API_KEY
FIREBASE_APP_ID=MY_FIREBASE_APP_ID
FIREBASE_PROJECT_ID=MY_FIREBASE_PROJECT_ID
